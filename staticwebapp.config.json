{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*",
      "serve": "/contacto.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/contacto.html",
    "exclude": ["/api/*", "/*.{css,js,png,ico,json}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/contacto.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".html": "text/html",
    ".json": "application/json"
  }
}
